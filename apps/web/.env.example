# ===========================================
# ConvoLens Web App - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ===========================================
# Authentication Provider
# ===========================================
# Production auth is handled by Mystira Identity through NextAuth.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-generated-secret
MYSTIRA_IDENTITY_WELL_KNOWN=https://identity.mystira.app/.well-known/openid-configuration
MYSTIRA_IDENTITY_CLIENT_ID=your-client-id
MYSTIRA_IDENTITY_CLIENT_SECRET=your-client-secret
MYSTIRA_IDENTITY_SCOPE=openid profile email


# ===========================================
# API Configuration
# ===========================================
# URL of the backend API server
NEXT_PUBLIC_API_URL=http://localhost:3001

# ===========================================
# AI Services (Optional - client-side)
# ===========================================
# Note: For production, AI calls should go through the API server
# Client-side keys are only for development/POC

# OpenAI API key for AI-powered summaries
# Get from: https://platform.openai.com/api-keys
# NEXT_PUBLIC_OPENAI_API_KEY=sk-...

# Azure OpenAI (preferred for enterprise)
# NEXT_PUBLIC_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# NEXT_PUBLIC_AZURE_OPENAI_DEPLOYMENT=gpt-4

# ===========================================
# Error Monitoring (Optional)
# ===========================================
# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Azure Application Insights (alternative)
# NEXT_PUBLIC_AZURE_APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;...

# ===========================================
# Analytics (Optional)
# ===========================================
# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Azure Application Insights for analytics
# NEXT_PUBLIC_AZURE_APP_INSIGHTS_INSTRUMENTATION_KEY=your-key

# ===========================================
# Feature Flags
# ===========================================
NEXT_PUBLIC_FEATURE_AI_SUMMARY=true
NEXT_PUBLIC_FEATURE_CHROME_EXTENSION=true
NEXT_PUBLIC_FEATURE_EXPORT_PDF=false
NEXT_PUBLIC_FEATURE_REAL_TIME_ANALYSIS=false

# ===========================================
# Development Settings
# ===========================================
# Set to false to disable mock authentication fallback
NEXT_PUBLIC_ALLOW_DEV_AUTH=true

# Enable debug mode for detailed console logging
# NEXT_PUBLIC_DEBUG=true

# ===========================================
# CDN & Assets (Production)
# ===========================================
# Azure Blob Storage CDN for static assets
# NEXT_PUBLIC_CDN_URL=https://yourstorage.blob.core.windows.net/assets

# ===========================================
# Rate Limiting (Client-side)
# ===========================================
# Maximum API requests per minute
NEXT_PUBLIC_RATE_LIMIT_MAX=60
